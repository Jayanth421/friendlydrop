rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdminRole() {
      return isSignedIn() && (
        request.auth.token.role == 'staff' ||
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'super_admin'
      );
    }

    function isManagerRole() {
      return isSignedIn() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'super_admin'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId || isAdminRole();
      allow update: if isSignedIn() && request.auth.uid == userId || isAdminRole();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isManagerRole();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid || isAdminRole();
      allow update: if isAdminRole();
      allow delete: if false;
    }

    match /transactions/{txnId} {
      allow read: if isAdminRole();
      allow write: if isAdminRole();
    }

    match /cart/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /wishlist/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /uploads/{uploadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdminRole();
      allow delete: if false;
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdminRole();
      allow delete: if false;
    }

    match /coupons/{couponId} {
      allow read: if isAdminRole();
      allow write: if isManagerRole();
    }

    match /activityLogs/{logId} {
      allow read: if isAdminRole();
      allow write: if isAdminRole();
    }

    match /auditLogs/{logId} {
      allow read: if isManagerRole();
      allow write: if isAdminRole();
    }

    match /supportTickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminRole());
      allow create: if isSignedIn();
      allow update: if isAdminRole();
      allow delete: if false;
    }

    match /returns/{returnId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdminRole());
      allow create: if isSignedIn();
      allow update: if isAdminRole();
      allow delete: if false;
    }

    match /settings/{docId} {
      allow read, write: if isManagerRole();
    }

    match /admin2faChallenges/{challengeId} {
      allow read, write: if isAdminRole();
    }

    match /adminSessions/{sessionId} {
      allow read, write: if isAdminRole();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
